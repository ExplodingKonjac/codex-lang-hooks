{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/post_edit_hook.mjs\"",
            "timeout": 180,
            "statusMessage": "Running configured JavaScript/TypeScript edit checks"
          }
        ],
        "description": "Run configured JavaScript and TypeScript formatting on modified files after edits",
        "id": "js-lang-hooks:post-edit-format"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/stop_hook.mjs\"",
            "timeout": 180,
            "statusMessage": "Running configured JavaScript/TypeScript stop checks"
          }
        ],
        "description": "Run configured JavaScript and TypeScript type checking, linting, and tests for affected projects",
        "id": "js-lang-hooks:stop-checks"
      }
    ]
  }
}
