{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/post_edit_hook.mjs\"",
            "timeout": 180,
            "statusMessage": "Running configured Rust edit checks"
          }
        ],
        "description": "Run configured cargo fmt or rustfmt formatting on modified Rust files after edits",
        "id": "rust-lang-hooks:post-edit-format"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/stop_hook.mjs\"",
            "timeout": 180,
            "statusMessage": "Running configured Rust stop checks"
          }
        ],
        "description": "Run configured cargo check, cargo clippy, and cargo test checks for affected Rust projects",
        "id": "rust-lang-hooks:stop-checks"
      }
    ]
  }
}
