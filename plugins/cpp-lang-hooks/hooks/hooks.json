{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/post_edit_hook.mjs\"",
            "timeout": 180,
            "statusMessage": "Running configured C++ edit checks"
          }
        ],
        "description": "Run configured clang-format and clang-tidy checks on modified C/C++ files after edits",
        "id": "cpp-lang-hooks:post-edit-clang-format"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/stop_hook.mjs\"",
            "timeout": 180,
            "statusMessage": "Running configured C++ stop checks"
          }
        ],
        "description": "Run configured CMake build and ctest checks when available",
        "id": "cpp-lang-hooks:stop-checks"
      }
    ]
  }
}
